{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.SBolivarLoL/clover-mcp",
  "title": "Clover POS",
  "description": "Clover POS for a single merchant: sales, inventory, orders, customers (reads + safe writes).",
  "version": "0.5.0",
  "repository": {
    "url": "https://github.com/SBolivarLoL/clover-mcp-server",
    "source": "github"
  },
  "packages": [
    {
      "registryType": "pypi",
      "identifier": "clover-mcp",
      "version": "0.5.0",
      "transport": { "type": "stdio" },
      "runtimeHint": "uvx",
      "environmentVariables": [
        { "name": "CLOVER_MERCHANT_ID", "description": "Clover merchant ID", "isRequired": true, "isSecret": false },
        { "name": "CLOVER_ACCESS_TOKEN", "description": "Clover API access token", "isRequired": true, "isSecret": true },
        { "name": "CLOVER_REGION", "description": "Clover API region: na | eu | la", "isRequired": false, "isSecret": false, "default": "na" },
        { "name": "CLOVER_SANDBOX", "description": "Use the Clover sandbox host when true", "isRequired": false, "isSecret": false, "default": "false" },
        { "name": "CLOVER_AUTH_MODE", "description": "Auth mode: token | oauth_refresh", "isRequired": false, "isSecret": false, "default": "token" },
        { "name": "CLOVER_REFRESH_TOKEN", "description": "OAuth refresh token (oauth_refresh mode)", "isRequired": false, "isSecret": true },
        { "name": "CLOVER_OAUTH_CLIENT_ID", "description": "OAuth app client ID (oauth_refresh mode)", "isRequired": false, "isSecret": false },
        { "name": "CLOVER_OAUTH_CLIENT_SECRET", "description": "OAuth app client secret (oauth_refresh mode)", "isRequired": false, "isSecret": true }
      ]
    }
  ]
}
